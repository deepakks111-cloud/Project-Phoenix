//=============================================================================
// PROJECT PHOENIX
// MODULE : Main Execution Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Deterministic global-scope orchestration for the Phoenix Pine runtime.
//=============================================================================


//=============================================================================
// 1. CALCULATION LAYER
//=============================================================================

[phxNextEMA20, phxNextEMA50, phxNextEMA200, phxNextBullTrend, phxNextBearTrend, phxNextNeutralTrend] = phxBuildEMA(close)

int phxNextTrend = not ENABLE_TREND_ENGINE ? PHX_TREND_UNKNOWN : phxNextBullTrend ? PHX_TREND_BULL : phxNextBearTrend ? PHX_TREND_BEAR : PHX_TREND_RANGE
phxNextTrend := phxNormalizeTrend(phxNextTrend)

string phxNextTrendName = phxTrendName(phxNextTrend)
color phxNextTrendColor = phxTrendColor(phxNextTrend)

int phxNextSignal = ENABLE_TREND_ENGINE ? phxResolveSignal(phxNextBullTrend, phxNextBearTrend) : PHX_SIGNAL_NONE
phxNextSignal := phxNormalizeSignal(phxNextSignal)

bool phxNextTrendChanged = PHX_STATE_INITIALIZED and phxHasTrendChanged(PHX_CURRENT_TREND, phxNextTrend)
bool phxNextSignalChanged = PHX_STATE_INITIALIZED and phxHasSignalChanged(PHX_CURRENT_SIGNAL, phxNextSignal)
bool phxNewActionableSignal = phxNextSignalChanged and phxIsActionableSignal(phxNextSignal)

string phxNextSignalId = phxNewActionableSignal ? phxBuildSignalId(syminfo.tickerid, timeframe.period, phxNextSignal, time, bar_index) : PHX_SIGNAL_ID
int phxNextSignalBar = phxNewActionableSignal ? bar_index : PHX_SIGNAL_BAR
int phxNextSignalTime = phxNewActionableSignal ? time : PHX_SIGNAL_TIME

bool phxNextAlertTriggered = ENABLE_ALERT_ENGINE and barstate.isconfirmed and phxNewActionableSignal
string phxNextAlertEventId = phxNextAlertTriggered ? phxNextSignalId : PHX_ALERT_EVENT_ID
int phxNextAlertBar = phxNextAlertTriggered ? bar_index : PHX_ALERT_BAR


//=============================================================================
// 2. SINGLE STATE COMMIT
//=============================================================================

PHX_EMA20 := phxNextEMA20
PHX_EMA50 := phxNextEMA50
PHX_EMA200 := phxNextEMA200

PHX_PREVIOUS_TREND := PHX_CURRENT_TREND
PHX_CURRENT_TREND := phxNextTrend
PHX_CURRENT_TREND_NAME := phxNextTrendName
PHX_CURRENT_TREND_COLOR := phxNextTrendColor
PHX_TREND_CHANGED := phxNextTrendChanged

PHX_PREVIOUS_SIGNAL := PHX_CURRENT_SIGNAL
PHX_CURRENT_SIGNAL := phxNextSignal
PHX_SIGNAL_CHANGED := phxNextSignalChanged
PHX_SIGNAL_ID := phxNextSignalId
PHX_SIGNAL_BAR := phxNextSignalBar
PHX_SIGNAL_TIME := phxNextSignalTime

PHX_ALERT_TRIGGERED := phxNextAlertTriggered
PHX_ALERT_EVENT_ID := phxNextAlertEventId
PHX_ALERT_BAR := phxNextAlertBar

PHX_STATE_INITIALIZED := true
PHX_STATE_BAR_INDEX := bar_index
PHX_STATE_TIME := time
PHX_STATE_CONFIRMED := barstate.isconfirmed


//=============================================================================
// 3. GLOBAL-SCOPE VISUAL OUTPUTS
//=============================================================================

plot(phxEMA20PlotValue(PHX_EMA20), title = "EMA 20", color = color.aqua, linewidth = 2)
plot(phxEMA50PlotValue(PHX_EMA50), title = "EMA 50", color = color.orange, linewidth = 2)
plot(phxEMA200PlotValue(PHX_EMA200), title = "EMA 200", color = color.red, linewidth = 3)
bgcolor(phxBackgroundPlotColor(PHX_CURRENT_TREND), title = "Phoenix Trend Background")


//=============================================================================
// 4. CONTROLLED TREND LABEL
//=============================================================================

var label phxTrendLabel = na
bool phxShowTrendLabel = phxShouldShowTrendLabel()

if phxShowTrendLabel
    if na(phxTrendLabel)
        phxTrendLabel := label.new(bar_index, high, PHX_CURRENT_TREND_NAME, style = label.style_label_down, color = PHX_CURRENT_TREND_COLOR, textcolor = color.white, size = size.small)
    else
        label.set_xy(phxTrendLabel, bar_index, high)
        label.set_text(phxTrendLabel, PHX_CURRENT_TREND_NAME)
        label.set_color(phxTrendLabel, PHX_CURRENT_TREND_COLOR)
        label.set_textcolor(phxTrendLabel, color.white)
else if not na(phxTrendLabel)
    label.delete(phxTrendLabel)
    phxTrendLabel := na


//=============================================================================
// 5. DASHBOARD
//=============================================================================

if ENABLE_DASHBOARD and barstate.islast
    phxRenderDashboard()


//=============================================================================
// END OF MODULE
//=============================================================================
