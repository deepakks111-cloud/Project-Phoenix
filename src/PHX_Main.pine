//=============================================================================
// PROJECT PHOENIX
// MODULE : Main Execution Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001
// Version : v0.1.0
//
// Purpose
// -------
// Central execution engine.
//
// This module controls the execution order of every Phoenix component.
//
// Nothing in Phoenix should bypass this execution flow.
//=============================================================================


//=============================================================================
// MAIN EXECUTION
//=============================================================================

phxExecute() =>

    //---------------------------------------------------------------------
    // 1. BUILD EMA ENGINE
    //---------------------------------------------------------------------

    [
        ema20,
        ema50,
        ema200,
        bullTrend,
        bearTrend,
        neutralTrend
    ] = phxBuildEMA(close)

    phxUpdateEMAState(
        ema20,
        ema50,
        ema200
    )

    //---------------------------------------------------------------------
    // 2. BUILD TREND ENGINE
    //---------------------------------------------------------------------

    [
        trend,
        trendName,
        trendColor
    ] = phxTrendEngine(close)

    phxUpdateTrendState(
        trend,
        trendName,
        trendColor
    )

    //---------------------------------------------------------------------
    // 3. SIGNAL ENGINE
    //---------------------------------------------------------------------

    signal = PHX_SIGNAL_NONE

    if bullTrend
        signal := PHX_SIGNAL_BUY

    if bearTrend
        signal := PHX_SIGNAL_SELL

    phxUpdateSignalState(signal)

    //---------------------------------------------------------------------
    // 4. VISUALIZATION
    //---------------------------------------------------------------------

    phxRender(
        ema20,
        ema50,
        ema200,
        trend,
        trendName
    )

    //---------------------------------------------------------------------
    // 5. DASHBOARD
    //---------------------------------------------------------------------

    phxRenderDashboard()

    //---------------------------------------------------------------------
    // 6. ALERT ENGINE
    //---------------------------------------------------------------------

    phxProcessAlerts()

    //---------------------------------------------------------------------
    // END
    //---------------------------------------------------------------------


//=============================================================================
// END OF MODULE
//=============================================================================
