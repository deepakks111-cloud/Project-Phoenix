//=============================================================================
// PROJECT PHOENIX
// MODULE : Trend Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Central trend-detection engine.
//
// Design rules
// ------------
// • Canonical trend constants are declared only in PHX_Types.pine.
// • EMA calculations are delegated to PHX_EMA.pine.
// • Functions are pure and do not mutate runtime state.
//=============================================================================


//=============================================================================
// EMA TREND
//=============================================================================

phxEMATrend(series float source) =>
    [ema20, ema50, ema200, bullTrend, bearTrend, neutralTrend] = phxBuildEMA(source)
    int trend = PHX_TREND_UNKNOWN
    if bullTrend
        trend := PHX_TREND_BULL
    else if bearTrend
        trend := PHX_TREND_BEAR
    else
        trend := PHX_TREND_RANGE
    trend


//=============================================================================
// TREND NAME
//=============================================================================

phxTrendName(int trend) =>
    trend == PHX_TREND_BULL ? "Bullish" : trend == PHX_TREND_BEAR ? "Bearish" : trend == PHX_TREND_RANGE ? "Range" : "Unknown"


//=============================================================================
// TREND COLOR
//=============================================================================

phxTrendColor(int trend) =>
    trend == PHX_TREND_BULL ? color.lime : trend == PHX_TREND_BEAR ? color.red : color.orange


//=============================================================================
// TREND VALIDATION
//=============================================================================

phxIsBullTrend(int trend) =>
    trend == PHX_TREND_BULL


phxIsBearTrend(int trend) =>
    trend == PHX_TREND_BEAR


phxIsRange(int trend) =>
    trend == PHX_TREND_RANGE


//=============================================================================
// MASTER TREND ENGINE
//=============================================================================

phxTrendEngine(series float source) =>
    int trend = phxEMATrend(source)
    [trend, phxTrendName(trend), phxTrendColor(trend)]


//=============================================================================
// END OF MODULE
//=============================================================================
