// Purpose
// -------
// Central Trend Detection Engine.
//
// This module becomes the single source of truth for trend determination.
//
// Current Inputs
// --------------
// • EMA Alignment
// • EMA Slope
//
// Future Inputs
// -------------
// • Market Structure
// • BOS
// • CHoCH
// • Swing Structure
// • Liquidity
// • Order Blocks
// • Fair Value Gaps
//=============================================================================


//=============================================================================
// TREND ENUMERATION
//=============================================================================

const int PHX_TREND_UNKNOWN = 0
const int PHX_TREND_BULL    = 1
const int PHX_TREND_BEAR    = -1
const int PHX_TREND_RANGE   = 2


//=============================================================================
// EMA TREND
//=============================================================================

phxEMATrend(series float source) =>

    [
        ema20,
        ema50,
        ema200,
        bullTrend,
        bearTrend,
        neutralTrend
    ] = phxBuildEMA(source)

    trend = PHX_TREND_UNKNOWN

    if bullTrend
        trend := PHX_TREND_BULL
    else if bearTrend
        trend := PHX_TREND_BEAR
    else
        trend := PHX_TREND_RANGE

    trend


//=============================================================================
// TREND NAME
//=============================================================================

phxTrendName(int trend)=>

    trend == PHX_TREND_BULL ?
         "Bullish" :

    trend == PHX_TREND_BEAR ?
         "Bearish" :

    trend == PHX_TREND_RANGE ?
         "Range" :

    "Unknown"


//=============================================================================
// TREND COLOR
//=============================================================================

phxTrendColor(int trend)=>

    trend == PHX_TREND_BULL ?
        color.lime :

    trend == PHX_TREND_BEAR ?
        color.red :

    color.orange


//=============================================================================
// TREND VALIDATION
//=============================================================================

phxIsBullTrend(int trend)=>
    trend == PHX_TREND_BULL


phxIsBearTrend(int trend)=>
    trend == PHX_TREND_BEAR


phxIsRange(int trend)=>
    trend == PHX_TREND_RANGE


//=============================================================================
// MASTER TREND ENGINE
//=============================================================================

phxTrendEngine(series float source)=>

    trend = phxEMATrend(source)

    [
        trend,
        phxTrendName(trend),
        phxTrendColor(trend)
    ]


