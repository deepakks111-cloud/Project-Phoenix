//=============================================================================
// PROJECT PHOENIX
// MODULE : Core Framework
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Shared framework helpers used by Phoenix modules.
//
// Design rules
// ------------
// • Canonical constants are declared only in PHX_Types.pine.
// • Core helpers are pure and do not mutate global runtime state.
// • Runtime state is owned by PHX_State.pine and committed by PHX_Main.pine.
//=============================================================================


//=============================================================================
// RELEASE METADATA
//=============================================================================

var string PHX_CURRENT_RELEASE = PHX_VERSION
var string PHX_CURRENT_THEME   = PHX_THEME


//=============================================================================
// VALIDATION HELPERS
//=============================================================================

phxIsPositive(int value) =>
    value > 0


phxIsEnabled(bool flag) =>
    flag


//=============================================================================
// MATHEMATICAL HELPERS
//=============================================================================

phxMax(float a, float b) =>
    math.max(a, b)


phxMin(float a, float b) =>
    math.min(a, b)


phxAverage(float a, float b) =>
    (a + b) / 2.0


//=============================================================================
// PRICE HELPERS
//=============================================================================

phxTypicalPrice() =>
    (high + low + close) / 3.0


phxMedianPrice() =>
    (high + low) / 2.0


//=============================================================================
// BAR HELPERS
//=============================================================================

phxIsBullBar() =>
    close > open


phxIsBearBar() =>
    close < open


phxBarRange() =>
    high - low


//=============================================================================
// END OF MODULE
//=============================================================================
