//=============================================================================
// PROJECT PHOENIX
// MODULE : State Manager
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Central, deterministic runtime state for Project Phoenix.
//
// Design rules
// ------------
// • This module owns state declarations and pure state helpers only.
// • Functions in this module do not mutate global variables.
// • PHX_Main.pine calculates the next state and commits it once per bar.
// • Visualisation, dashboard and alerts read the committed state.
//=============================================================================


//=============================================================================
// EMA STATE
//=============================================================================

var float PHX_EMA20  = na
var float PHX_EMA50  = na
var float PHX_EMA200 = na


//=============================================================================
// TREND STATE
//=============================================================================

var int    PHX_CURRENT_TREND       = PHX_TREND_UNKNOWN
var int    PHX_PREVIOUS_TREND      = PHX_TREND_UNKNOWN
var string PHX_CURRENT_TREND_NAME  = "Unknown"
var color  PHX_CURRENT_TREND_COLOR = color.gray
var bool   PHX_TREND_CHANGED       = false


//=============================================================================
// SIGNAL STATE
//=============================================================================

var int    PHX_CURRENT_SIGNAL  = PHX_SIGNAL_NONE
var int    PHX_PREVIOUS_SIGNAL = PHX_SIGNAL_NONE
var bool   PHX_SIGNAL_CHANGED  = false
var string PHX_SIGNAL_ID       = ""
var int    PHX_SIGNAL_BAR      = na
var int    PHX_SIGNAL_TIME     = na


//=============================================================================
// MARKET-INTELLIGENCE STATE
// Reserved for later engines; initialized now to preserve one state contract.
//=============================================================================

var int PHX_MARKET_STRUCTURE = PHX_STRUCTURE_NONE
var int PHX_BOS_STATE        = PHX_BOS_NONE
var int PHX_CHOCH_STATE      = PHX_CHOCH_NONE
var int PHX_LIQUIDITY_STATE  = PHX_LIQUIDITY_NONE
var int PHX_FVG_STATE        = PHX_FVG_NONE
var int PHX_OB_STATE         = PHX_OB_NONE


//=============================================================================
// ALERT / EXECUTION BRIDGE STATE
//=============================================================================

var bool   PHX_ALERT_TRIGGERED = false
var string PHX_ALERT_EVENT_ID  = ""
var int    PHX_ALERT_BAR       = na


//=============================================================================
// FRAMEWORK STATE
//=============================================================================

var bool PHX_STATE_INITIALIZED = false
var int  PHX_STATE_BAR_INDEX   = na
var int  PHX_STATE_TIME        = na
var bool PHX_STATE_CONFIRMED   = false


//=============================================================================
// PURE VALIDATION HELPERS
//=============================================================================

phxValidTrend(int trend) =>
    trend == PHX_TREND_BULL or
    trend == PHX_TREND_BEAR or
    trend == PHX_TREND_RANGE or
    trend == PHX_TREND_UNKNOWN


phxValidSignal(int signal) =>
    signal == PHX_SIGNAL_BUY or
    signal == PHX_SIGNAL_SELL or
    signal == PHX_SIGNAL_NONE


phxNormalizeTrend(int trend) =>
    phxValidTrend(trend) ? trend : PHX_TREND_UNKNOWN


phxNormalizeSignal(int signal) =>
    phxValidSignal(signal) ? signal : PHX_SIGNAL_NONE


//=============================================================================
// PURE TRANSITION HELPERS
//=============================================================================

phxResolveSignal(bool bullCondition, bool bearCondition) =>
    bullCondition and not bearCondition ? PHX_SIGNAL_BUY :
    bearCondition and not bullCondition ? PHX_SIGNAL_SELL :
    PHX_SIGNAL_NONE


phxHasTrendChanged(int previousTrend, int currentTrend) =>
    phxNormalizeTrend(previousTrend) != phxNormalizeTrend(currentTrend)


phxHasSignalChanged(int previousSignal, int currentSignal) =>
    phxNormalizeSignal(previousSignal) != phxNormalizeSignal(currentSignal)


phxIsActionableSignal(int signal) =>
    normalizedSignal = phxNormalizeSignal(signal)
    normalizedSignal == PHX_SIGNAL_BUY or normalizedSignal == PHX_SIGNAL_SELL


phxSignalDirectionName(int signal) =>
    normalizedSignal = phxNormalizeSignal(signal)
    normalizedSignal == PHX_SIGNAL_BUY ? "LONG" :
    normalizedSignal == PHX_SIGNAL_SELL ? "SHORT" :
    "NONE"


phxBuildSignalId(string symbol, string timeframe, int signal, int signalTime, int signalBar) =>
    safeSymbol    = str.length(symbol) > 0 ? symbol : "UNKNOWN"
    safeTimeframe = str.length(timeframe) > 0 ? timeframe : "UNKNOWN"
    direction     = phxSignalDirectionName(signal)
    timePart      = str.tostring(signalTime)
    barPart       = str.tostring(signalBar)

    "PHX|" + safeSymbol + "|" + safeTimeframe + "|" + direction + "|" + timePart + "|" + barPart


//=============================================================================
// READ FUNCTIONS
//=============================================================================

phxTrend() =>
    PHX_CURRENT_TREND


phxTrendName() =>
    PHX_CURRENT_TREND_NAME


phxTrendColor() =>
    PHX_CURRENT_TREND_COLOR


phxSignal() =>
    PHX_CURRENT_SIGNAL


phxSignalId() =>
    PHX_SIGNAL_ID


phxStateReady() =>
    PHX_STATE_INITIALIZED


//=============================================================================
// END OF MODULE
//=============================================================================
