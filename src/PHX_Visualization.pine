//=============================================================================
// PROJECT PHOENIX
// MODULE : Visualization Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Pure visualization helpers only.
//
// Pine restrictions
// -----------------
// plot() and bgcolor() cannot be called from local scope or user functions.
// Their global-scope calls are therefore owned by PHX_Main.pine.
//=============================================================================


//=============================================================================
// TREND BACKGROUND COLOR
//=============================================================================

phxTrendBackgroundColor(int trend) =>
    trend == PHX_TREND_BULL ? color.new(color.green, 90) : trend == PHX_TREND_BEAR ? color.new(color.red, 90) : color.new(color.gray, 94)


//=============================================================================
// VISIBILITY HELPERS
//=============================================================================

phxEMA20PlotValue(float ema20) =>
    ENABLE_VISUALIZATION and ENABLE_EMA_ENGINE and SHOW_EMA20 ? ema20 : na


phxEMA50PlotValue(float ema50) =>
    ENABLE_VISUALIZATION and ENABLE_EMA_ENGINE and SHOW_EMA50 ? ema50 : na


phxEMA200PlotValue(float ema200) =>
    ENABLE_VISUALIZATION and ENABLE_EMA_ENGINE and SHOW_EMA200 ? ema200 : na


phxBackgroundPlotColor(int trend) =>
    ENABLE_VISUALIZATION and ENABLE_TREND_ENGINE and SHOW_TREND_BACKGROUND ? phxTrendBackgroundColor(trend) : na


phxShouldShowTrendLabel() =>
    ENABLE_VISUALIZATION and ENABLE_TREND_ENGINE and SHOW_TREND_LABELS and barstate.islast


//=============================================================================
// END OF MODULE
//=============================================================================
