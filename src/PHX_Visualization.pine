//=============================================================================
// PROJECT PHOENIX
// MODULE : Visualization Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001
// Version : v0.1.0
//
// Purpose
// -------
// Central visualization engine.
//
// Responsible for all chart rendering including:
//
// • EMA plots
// • Trend colouring
// • Trend labels
// • Future Dashboard
// • Future Smart Money objects
//
// NOTE
// ----
// No calculations are performed here.
// Visualization only.
//=============================================================================


//=============================================================================
// EMA VISUALIZATION
//=============================================================================

phxPlotEMAs(float ema20, float ema50, float ema200)=>

    if SHOW_EMA20
        plot(
             ema20,
             title="EMA 20",
             color=color.aqua,
             linewidth=2
        )

    if SHOW_EMA50
        plot(
             ema50,
             title="EMA 50",
             color=color.orange,
             linewidth=2
        )

    if SHOW_EMA200
        plot(
             ema200,
             title="EMA 200",
             color=color.red,
             linewidth=3
        )


//=============================================================================
// TREND BACKGROUND
//=============================================================================

phxPlotTrendBackground(int trend)=>

    if SHOW_TREND_BACKGROUND

        bgcolor(

            trend == PHX_TREND_BULL ?

                color.new(color.green,90)

            :

            trend == PHX_TREND_BEAR ?

                color.new(color.red,90)

            :

                color.new(color.gray,94)

        )


//=============================================================================
// TREND LABEL
//=============================================================================

phxPlotTrendLabel(int trend,string trendName)=>

    if SHOW_TREND_LABELS

        var label trendLabel = na

        label.delete(trendLabel)

        trendLabel := label.new(

            bar_index,

            high,

            trendName,

            style=label.style_label_down,

            color=phxTrendColor(trend),

            textcolor=color.white,

            size=size.small

        )


//=============================================================================
// MASTER VISUALIZATION
//=============================================================================

phxRender(

    float ema20,

    float ema50,

    float ema200,

    int trend,

    string trendName

)=>

    phxPlotEMAs(

        ema20,

        ema50,

        ema200

    )

    phxPlotTrendBackground(

        trend

    )

    phxPlotTrendLabel(

        trend,

        trendName

    )


