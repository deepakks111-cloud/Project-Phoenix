//=============================================================================
// PROJECT PHOENIX
// MODULE : EMA Engine
//-----------------------------------------------------------------------------
// Release : PHX-R001 / RC0-011A
// Version : v0.1.0
//
// Purpose
// -------
// Centralized EMA calculations and EMA-based trend helpers.
//=============================================================================


//=============================================================================
// EMA CALCULATIONS
//=============================================================================

phxEMAFast(series float source) =>
    ta.ema(source, EMA_FAST_LENGTH)


phxEMAMid(series float source) =>
    ta.ema(source, EMA_MID_LENGTH)


phxEMASlow(series float source) =>
    ta.ema(source, EMA_SLOW_LENGTH)


//=============================================================================
// TREND RELATIONSHIPS
//=============================================================================

phxBullTrend(float emaFast, float emaMid, float emaSlow) =>
    emaFast > emaMid and emaMid > emaSlow


phxBearTrend(float emaFast, float emaMid, float emaSlow) =>
    emaFast < emaMid and emaMid < emaSlow


phxNeutralTrend(float emaFast, float emaMid, float emaSlow) =>
    not phxBullTrend(emaFast, emaMid, emaSlow) and not phxBearTrend(emaFast, emaMid, emaSlow)


//=============================================================================
// PRICE POSITION
//=============================================================================

phxPriceAboveEMA(series float price, float emaValue) =>
    price > emaValue


phxPriceBelowEMA(series float price, float emaValue) =>
    price < emaValue


//=============================================================================
// EMA SLOPE
//=============================================================================

phxEMARising(float emaValue) =>
    emaValue > emaValue[1]


phxEMAFalling(float emaValue) =>
    emaValue < emaValue[1]


//=============================================================================
// CROSS DETECTION
//=============================================================================

phxBullCross(float emaFast, float emaMid) =>
    ta.crossover(emaFast, emaMid)


phxBearCross(float emaFast, float emaMid) =>
    ta.crossunder(emaFast, emaMid)


//=============================================================================
// MASTER EMA STRUCTURE
//=============================================================================

phxBuildEMA(series float source) =>
    float ema20 = phxEMAFast(source)
    float ema50 = phxEMAMid(source)
    float ema200 = phxEMASlow(source)
    bool bullTrend = phxBullTrend(ema20, ema50, ema200)
    bool bearTrend = phxBearTrend(ema20, ema50, ema200)
    bool neutralTrend = not bullTrend and not bearTrend
    [ema20, ema50, ema200, bullTrend, bearTrend, neutralTrend]


//=============================================================================
// END OF MODULE
//=============================================================================
